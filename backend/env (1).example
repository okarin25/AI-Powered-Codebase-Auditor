# Required
GOOGLE_API_KEY=your_gemini_api_key_here

# Security — set this before deploying publicly, otherwise anyone who finds
# your URL can spend your Gemini quota. Leave unset for local dev.
API_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Repo / analysis limits
MAX_REPO_SIZE_MB=50
MAX_FILES_TO_ANALYZE=25
CLONE_TIMEOUT_SECONDS=60
SUBPROCESS_TIMEOUT_SECONDS=30

# Job lifecycle (in-memory job store)
JOB_TTL_HOURS=6
MAX_CONCURRENT_JOBS=3

# Gemini call throttling — set to your actual free-tier RPM for whichever
# model gets selected. Check https://ai.google.dev/gemini-api/docs/rate-limits
GEMINI_REQUESTS_PER_MINUTE=4
AGENT_MAX_ITERATIONS=8

# Rate limiting (slowapi syntax, e.g. "5/minute", "100/day")
RATE_LIMIT_AUDIT=5/minute

# Logging
LOG_LEVEL=INFO
